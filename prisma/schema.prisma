generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  stripeCustomerId String?
  mrr              Int            @default(0)
  apiKey           String?        @unique @default(cuid())
  crmType          String?
  crmApiKey        String?
  customers        Customer[]
  playbooks        Playbook[]
  subscriptions    Subscription[]
  revenueMetrics   RevenueMetrics[]
}

model Customer {
  id          String   @id @default(cuid())
  userId      String
  externalId  String   
  email       String
  name        String?
  mrr         Int      @default(0)
  arr         Int      @default(0)
  riskScore   Int      @default(50)
  crmId       String?  
  healthScore Int?     @default(100) // CRM health score
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  events      Event[]
  
  @@unique([userId, externalId])
}

model Event {
  id          String   @id @default(cuid())
  customerId  String
  event       String   
  metadata    Json?
  timestamp   BigInt
  createdAt   DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Playbook {
  id          String    @id @default(cuid())
  userId      String
  name        String
  trigger     String
  description String?
  isActive    Boolean   @default(true)
  actions     Json?
  lastRun     DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  status    String
  priceId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model RevenueMetrics {
  id         String   @id @default(cuid())
  userId     String
  totalMrr   Int      @default(0)
  atRiskMrr  Int      @default(0)
  savedMrr   Int      @default(0)
  date       DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}
