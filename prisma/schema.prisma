generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String           @id @default(cuid())
  clerkId            String?          @unique
  email              String           @unique
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  stripeCustomerId   String?
  mrr                Int              @default(0)
  apiKey             String?          @unique @default(cuid())
  crmType            String?
  crmApiKey          String?
  slackWebhookUrl    String?
  widgetEnabled      Boolean?         @default(true)
  alertFrequency     String           @default("immediate")
  alertRiskThreshold Int              @default(70)
  company            String?
  name               String?
  notifEmail         Boolean          @default(true)
  notifSlack         Boolean          @default(false)
  timezone           String?          @default("UTC")
  automationRules    AutomationRule[]
  customers          Customer[]
  emailCampaigns     EmailCampaign[]
  playbooks          Playbook[]
  revenueMetrics     RevenueMetrics?
  slackAlerts        SlackAlert[]
  subscriptions      Subscription[]
  teamMembers        TeamMember[]
  webhooks           Webhook[]
  widgetMessages     WidgetMessage[]
}

model Customer {
  id                  String                @id @default(cuid())
  userId              String
  externalId          String
  email               String
  name                String?
  mrr                 Int                   @default(0)
  arr                 Int                   @default(0)
  riskScore           Int                   @default(50)
  crmId               String?
  healthScore         Int?                  @default(100)
  plan                String?               @default("free")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  featuresUsed        Json?
  lastLoginAt         DateTime?
  loginCountThisMonth Int                   @default(0)
  riskReason          String?
  lastFeatureUsedAt   DateTime?
  csmStatus           String?
  phone               String?
  activityLogs        ActivityLog[]
  user                User                  @relation(fields: [userId], references: [id])
  events              Event[]
  interventions       InterventionOutcome[]
  sequenceEnrollments SequenceEnrollment[]

  @@unique([userId, externalId])
}

model Event {
  id         String   @id @default(cuid())
  customerId String
  event      String
  metadata   Json?
  timestamp  BigInt
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Playbook {
  id          String    @id @default(cuid())
  userId      String
  name        String
  trigger     String
  description String?
  isActive    Boolean   @default(true)
  actions     Json?
  lastRun     DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  status    String
  priceId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model RevenueMetrics {
  id             String   @id @default(cuid())
  userId         String   @unique
  totalMrr       Int      @default(0)
  atRiskMrr      Int      @default(0)
  savedMrr       Int      @default(0)
  totalArr       Int      @default(0)
  atRiskArr      Int      @default(0)
  highValueCount Int      @default(0)
  date           DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

model SlackAlert {
  id           String   @id @default(cuid())
  userId       String
  customerId   String?
  alertType    String?
  mrrAtRisk    Int?     @default(0)
  messageSent  Boolean? @default(false)
  errorMessage String?
  message      String?
  riskScore    Int?
  sentAt       DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model WidgetMessage {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  content   String?
  trigger   String?  @default("manual")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AlertLog {
  id         String   @id @default(cuid())
  userId     String
  customerId String?
  type       String
  message    String
  sentAt     DateTime @default(now())

  @@index([userId])
  @@index([customerId])
  @@index([sentAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  customerId  String
  type        String
  description String
  createdAt   DateTime @default(now())
  userId      String?
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([createdAt])
  @@index([userId])
}

model Task {
  id          String    @id @default(cuid())
  customerId  String
  userId      String
  type        String
  title       String
  status      String    @default("pending")
  priority    String
  dueDate     DateTime
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([customerId])
  @@index([userId])
  @@index([status])
}

model CrmIntegration {
  id            String    @id @default(cuid())
  userId        String
  type          String
  enabled       Boolean   @default(false)
  accessToken   String?
  refreshToken  String?
  expiresAt     DateTime?
  instanceUrl   String?
  syncDirection String    @default("bidirectional")
  lastSyncAt    DateTime?
  syncStatus    String    @default("disconnected")
  lastError     String?
  fieldMappings String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

model CrmSyncLog {
  id         String   @id @default(cuid())
  userId     String
  crmType    String
  direction  String
  entityType String
  entityId   String
  status     String
  message    String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model InterventionOutcome {
  id               String    @id @default(cuid())
  userId           String
  customerId       String
  playbookId       String?
  interventionType String
  triggerEvent     String?
  mrrAtRisk        Int
  mrrSaved         Int       @default(0)
  mrrLost          Int       @default(0)
  interventionCost Int       @default(0)
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  churnedAt        DateTime?
  customerSegment  String?
  riskScoreAtStart Int
  daysSinceLogin   Int?
  plan             String?
  status           String    @default("pending")
  notes            String?
  successful       Boolean?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([customerId])
  @@index([interventionType])
  @@index([status])
  @@index([successful])
}

model RecommendationPattern {
  id                String   @id @default(cuid())
  userId            String
  customerSegment   String
  riskRangeMin      Int
  riskRangeMax      Int
  plan              String?
  recommendedAction String
  timesAttempted    Int      @default(0)
  timesSuccessful   Int      @default(0)
  avgMrrSaved       Int      @default(0)
  successRate       Float    @default(0)
  lastUsed          DateTime @default(now())
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([customerSegment])
  @@index([riskRangeMin, riskRangeMax])
  @@index([successRate])
}

model EmailCampaign {
  id          String    @id @default(cuid())
  userId      String
  name        String
  subject     String
  content     String
  segment     String    @default("all")
  status      String    @default("draft")
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Webhook {
  id           String    @id @default(cuid())
  userId       String
  url          String
  events       String
  label        String?
  active       Boolean   @default(true)
  secret       String?
  lastTestedAt DateTime?
  lastStatus   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  email     String
  name      String?
  role      String   @default("viewer")
  status    String   @default("pending")
  invitedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId])
  @@index([email])
  @@index([status])
}

model AutomationRule {
  id           String          @id @default(cuid())
  userId       String
  name         String
  triggerType  String
  condition    Json
  actionType   String
  actionConfig Json
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  logs         AutomationLog[]
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([triggerType])
  @@index([isActive])
}

model AutomationLog {
  id          String         @id @default(cuid())
  ruleId      String
  customerId  String
  userId      String
  triggerType String
  actionType  String
  status      String
  message     String?
  executedAt  DateTime       @default(now())
  rule        AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([customerId])
  @@index([userId])
  @@index([executedAt])
}

model SequenceEnrollment {
  id           String        @id @default(cuid())
  userId       String
  customerId   String
  sequenceType String
  currentStep  Int           @default(0)
  nextRunAt    DateTime
  status       String        @default("active")
  metadata     Json?
  startedAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  logs         SequenceLog[]

  @@index([status, nextRunAt])
  @@index([customerId, sequenceType])
  @@index([userId])
}

model SequenceLog {
  id           String             @id @default(cuid())
  enrollmentId String
  step         Int
  action       String
  status       String
  message      String?
  executedAt   DateTime           @default(now())
  enrollment   SequenceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([executedAt])
}

model AuditLead {
  id                 String   @id @default(cuid())
  email              String
  stripeConnected    Boolean  @default(false)
  csvUploaded        Boolean  @default(false)
  monthlyChurnRate   Float
  revenueAtRisk      Int
  annualizedLoss     Int
  totalMrr           Int      @default(0)
  industryPercentile Int
  atRiskCustomers    Json
  createdAt          DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}
