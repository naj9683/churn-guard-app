generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  clerkId          String?        @unique
  email            String         @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  stripeCustomerId String?
  mrr              Int            @default(0)
  apiKey           String?        @unique @default(cuid())
  crmType          String?
  crmApiKey        String?
  slackWebhookUrl  String?        
  widgetEnabled    Boolean?       @default(true)
  widgetMessages   WidgetMessage[]
  customers        Customer[]
  playbooks        Playbook[]
  subscriptions    Subscription[]
  revenueMetrics   RevenueMetrics?
  slackAlerts      SlackAlert[]
}

model Customer {
  id          String   @id @default(cuid())
  userId      String
  externalId  String   
  email       String
  name        String?
  mrr         Int      @default(0)
  arr         Int      @default(0)
  riskScore   Int      @default(50)
  crmId       String?  
  healthScore Int?     @default(100)
  plan        String?  @default("free")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  events      Event[]
  
  @@unique([userId, externalId])
}

model Event {
  id          String   @id @default(cuid())
  customerId  String
  event       String   
  metadata    Json?
  timestamp   BigInt
  createdAt   DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Playbook {
  id          String    @id @default(cuid())
  userId      String
  name        String
  trigger     String
  description String?
  isActive    Boolean   @default(true)
  actions     Json?
  lastRun     DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  status    String
  priceId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model RevenueMetrics {
  id              String   @id @default(cuid())
  userId          String   @unique
  totalMrr        Int      @default(0)
  atRiskMrr       Int      @default(0)
  savedMrr        Int      @default(0)
  totalArr        Int      @default(0)
  atRiskArr       Int      @default(0)
  highValueCount  Int      @default(0)
  date            DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model SlackAlert {
  id            String   @id @default(cuid())
  userId        String
  customerId    String?
  alertType     String?
  mrrAtRisk     Int?     @default(0)
  messageSent   Boolean? @default(false)
  errorMessage  String?
  message       String?
  riskScore     Int?
  sentAt        DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model WidgetMessage {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  content   String?
  trigger   String?  @default("manual")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// Add these models to track alerts and tasks
model AlertLog {
  id          String   @id @default(cuid())
  userId      String
  customerId  String?
  type        String   // 'risk_alert', 'rar_threshold', 'vip_alert', 'digest'
  message     String
  sentAt      DateTime @default(now())
  
  @@index([userId])
  @@index([customerId])
  @@index([sentAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  customerId  String
  type        String   // 'contacted', 'task_created', etc.
  description String
  createdAt   DateTime @default(now())
  
  @@index([customerId])
  @@index([createdAt])
}

model Task {
  id          String   @id @default(cuid())
  customerId  String
  userId      String
  type        String
  title       String
  status      String   @default("pending")
  priority    String
  dueDate     DateTime
  createdAt   DateTime @default(now())
  completedAt DateTime?
  
  @@index([customerId])
  @@index([userId])
  @@index([status])
}
