generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  clerkId          String?        @unique
  email            String         @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  stripeCustomerId String?
  mrr              Int            @default(0)
  apiKey           String?        @unique @default(cuid())
  crmType          String?
  crmApiKey        String?
  slackWebhookUrl  String?        
  widgetEnabled    Boolean?       @default(true)
  widgetMessages   WidgetMessage[]
  customers        Customer[]
  playbooks        Playbook[]
  subscriptions    Subscription[]
  revenueMetrics   RevenueMetrics?
  slackAlerts      SlackAlert[]
  teamMembers      TeamMember[]
}

model Customer {
  id          String   @id @default(cuid())
  userId      String
  externalId  String   
  email       String
  name        String?
  mrr         Int      @default(0)
  arr         Int      @default(0)
  riskScore   Int      @default(50)
  crmId       String?  
  healthScore Int?     @default(100)
  plan        String?  @default("free")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  events      Event[]
  interventions InterventionOutcome[]
  
  @@unique([userId, externalId])
}

model Event {
  id          String   @id @default(cuid())
  customerId  String
  event       String   
  metadata    Json?
  timestamp   BigInt
  createdAt   DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Playbook {
  id          String    @id @default(cuid())
  userId      String
  name        String
  trigger     String
  description String?
  isActive    Boolean   @default(true)
  actions     Json?
  lastRun     DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  status    String
  priceId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model RevenueMetrics {
  id              String   @id @default(cuid())
  userId          String   @unique
  totalMrr        Int      @default(0)
  atRiskMrr       Int      @default(0)
  savedMrr        Int      @default(0)
  totalArr        Int      @default(0)
  atRiskArr       Int      @default(0)
  highValueCount  Int      @default(0)
  date            DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model SlackAlert {
  id            String   @id @default(cuid())
  userId        String
  customerId    String?
  alertType     String?
  mrrAtRisk     Int?     @default(0)
  messageSent   Boolean? @default(false)
  errorMessage  String?
  message       String?
  riskScore     Int?
  sentAt        DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model WidgetMessage {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  content   String?
  trigger   String?  @default("manual")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// Add these models to track alerts and tasks
model AlertLog {
  id          String   @id @default(cuid())
  userId      String
  customerId  String?
  type        String   // 'risk_alert', 'rar_threshold', 'vip_alert', 'digest'
  message     String
  sentAt      DateTime @default(now())
  
  @@index([userId])
  @@index([customerId])
  @@index([sentAt])
}

model ActivityLog {
  userId      String?
  id          String   @id @default(cuid())
  customerId  String
  type        String   // 'contacted', 'task_created', etc.
  description String
  createdAt   DateTime @default(now())
  
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  @@index([customerId])
  @@index([createdAt])
  @@index([userId])
}

model Task {
  id          String   @id @default(cuid())
  customerId  String
  userId      String
  type        String
  title       String
  status      String   @default("pending")
  priority    String
  dueDate     DateTime
  createdAt   DateTime @default(now())
  completedAt DateTime?
  
  @@index([customerId])
  @@index([userId])
  @@index([status])
}

// CRM Integration Models
model CrmIntegration {
  id              String   @id @default(cuid())
  userId          String   @unique
  type            String   // 'salesforce' or 'hubspot'
  enabled         Boolean  @default(false)
  
  // OAuth credentials
  accessToken     String?
  refreshToken    String?
  expiresAt       DateTime?
  instanceUrl     String?  // Salesforce instance URL or HubSpot portal URL
  
  // Sync settings
  syncDirection   String   @default("bidirectional") // 'to_crm', 'from_crm', 'bidirectional'
  lastSyncAt      DateTime?
  syncStatus      String   @default("disconnected") // 'connected', 'syncing', 'error'
  lastError       String?
  
  // Field mappings (JSON)
  fieldMappings   String?  // JSON: { "riskScore": "ChurnGuard_Risk_Score__c", ... }
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
}

model CrmSyncLog {
  id              String   @id @default(cuid())
  userId          String
  crmType         String
  direction       String   // 'to_crm' or 'from_crm'
  entityType      String   // 'customer', 'opportunity', etc.
  entityId        String
  status          String   // 'success', 'error', 'skipped'
  message         String?
  createdAt       DateTime @default(now())
  
  @@index([userId])
  @@index([createdAt])
}

// Track which interventions actually saved revenue
model InterventionOutcome {
  id            String    @id @default(cuid())
  userId        String
  customerId    String
  playbookId    String?
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  // Intervention details
  interventionType  String    // 'discount_offer', 'training_session', 'ceo_call', 'webinar_invite', etc.
  triggerEvent      String?   // What triggered it: 'risk_spike', 'login_streak_broken', 'support_ticket'
  
  // Financial tracking
  mrrAtRisk         Int       // MRR value when intervention started
  mrrSaved          Int       @default(0)  // Actual MRR retained
  mrrLost           Int       @default(0)  // If churned anyway
  interventionCost  Int       @default(0)  // Cost of discount/effort (optional)
  
  // Timeline
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  churnedAt     DateTime?  // If they churned despite intervention
  
  // Pattern matching data
  customerSegment   String?   // 'enterprise', 'smb', 'startup'
  riskScoreAtStart  Int
  daysSinceLogin    Int?
  plan              String?
  
  // Outcome tracking
  status        String    @default("pending") // 'pending', 'saved', 'churned', 'no_change'
  notes         String?
  
  // For AI pattern learning
  successful    Boolean?  // true if saved, false if churned
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([userId])
  @@index([customerId])
  @@index([interventionType])
  @@index([status])
  @@index([successful])
}

// Store patterns for Next Best Action AI
model RecommendationPattern {
  id              String   @id @default(cuid())
  userId          String
  
  // Pattern definition
  customerSegment     String    // 'enterprise', 'smb', etc.
  riskRangeMin        Int       // 0-100
  riskRangeMax        Int       // 0-100
  plan                String?   // 'pro', 'enterprise', etc.
  
  // What was recommended
  recommendedAction   String    // 'discount', 'training', 'ceo_call', etc.
  
  // Success metrics
  timesAttempted      Int       @default(0)
  timesSuccessful     Int       @default(0)
  avgMrrSaved         Int       @default(0)
  successRate         Float     @default(0)  // Calculated: timesSuccessful / timesAttempted
  
  // Metadata
  lastUsed            DateTime  @default(now())
  isActive            Boolean   @default(true)
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  @@index([userId])
  @@index([customerSegment])
  @@index([riskRangeMin, riskRangeMax])
  @@index([successRate])
}

// Team/Multi-user support
model TeamMember {
  id          String   @id @default(cuid())
  userId      String   // The owner/admin who invited them
  email       String
  name        String?
  role        String   @default("viewer") // admin, manager, viewer
  status      String   @default("pending") // pending, active, inactive
  invitedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, email])
  @@index([userId])
  @@index([email])
  @@index([status])
}
